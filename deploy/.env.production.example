# ============================================================================
# Flow CMS — production environment.  Copy to `.env` and fill in.
#   cp .env.production.example .env
# The one-line installer generates all secrets for you; only edit this by hand
# for a manual install.  Keep `.env` private (chmod 600) — it holds your secrets.
# ============================================================================

# ── Domain & TLS ────────────────────────────────────────────────────────────
# Your public address. Point this domain's A/AAAA record at the server first.
# Use `localhost` for a local test (Caddy serves an internal self-signed cert).
DOMAIN=cms.yoursite.com
# Email for Let's Encrypt (expiry notices). Leave empty when DOMAIN=localhost.
ACME_EMAIL=you@yoursite.com

# ── Database ────────────────────────────────────────────────────────────────
# Bundled Postgres (the `postgres` service). The installer sets a strong password.
POSTGRES_USER=flowcms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=flowcms
# What the API connects to. Default = the bundled service.
# To use Neon/Supabase/RDS instead: set this to that URL and stop the `postgres`
# service (see docs/DEPLOY.md → "Using an external database").
DATABASE_URL=postgresql://flowcms:CHANGE_ME_strong_db_password@postgres:5432/flowcms?schema=public

# ── Security secrets (REQUIRED) ─────────────────────────────────────────────
# Generate each with:  openssl rand -base64 32
# SECRETS_ENCRYPTION_KEY encrypts stored credentials (AI keys, SMTP, etc.).
#   ⚠ Never change it after first boot — it would make existing secrets unreadable.
SECRETS_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32
# JWT_SECRET signs login sessions. Rotating it logs everyone out.
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32

# ── App wiring ──────────────────────────────────────────────────────────────
NODE_ENV=production
# Must equal https://<DOMAIN> — used for CORS, websockets and email links.
STUDIO_URL=https://cms.yoursite.com
# Caddy is one proxy hop in front of the API (enables correct client IPs).
TRUST_PROXY=1
# Session cookie is Secure (HTTPS-only) by default in production. Set false ONLY if
# the app is served over plain http (a local test, or TLS terminated upstream and the
# app sees http) — otherwise the login cookie won't be stored. Leave unset for HTTPS.
# COOKIE_SECURE=true
# Browser API base — baked into the studio image AT BUILD TIME (build arg), so
# this runtime value is informational. Keep it relative (`/api`) so one image
# works on any domain behind the proxy.
NEXT_PUBLIC_API_URL=/api

# ── In-app updates & backups (the updater sidecar) ──────────────────────────
# The `updater` service performs full backups + the one-click upgrade. The API
# talks to it with this shared token; generate one with: openssl rand -base64 32.
UPDATER_TOKEN=CHANGE_ME_openssl_rand_base64_32
# Host path of THIS install dir (mounted into the updater so it can read .env +
# the compose file and write backups/). Match your install location.
FLOWCMS_HOST_DIR=/opt/flowcms
# Prebuilt updater image (override to your registry once published).
UPDATER_IMAGE=ghcr.io/flowcms-co/flowcms-updater:latest

# ── Public self-registration (off by default) ───────────────────────────────
# With this off, POST /api/auth/signup is refused and users join by admin invite
# (the first admin comes from the /welcome first-run wizard). Turn on ONLY for an
# intentionally open, public-signup CMS. SECURITY_AUDIT_REPORT F-02.
# SIGNUP_ENABLED=false

# ── First-run Super Admin (optional) ─────────────────────────────────────────
# On boot the entrypoint runs prisma/bootstrap.ts (workspace + roles, NO deletes).
# Leave SEED_ADMIN_* UNSET to boot "unclaimed" and create your admin in the browser
# /welcome wizard. Set BOTH to provision it non-interactively (and skip /welcome).
# (The destructive demo seed.ts is dev-only, run manually via `npm run db:seed`.)
# SEED_ADMIN_EMAIL=admin@yoursite.com
# SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
SEED_ON_BOOT=true                                      # idempotent bootstrap; safe to leave on

# ── Commercial license (optional; Community needs none) ──────────────────────
# FLOWCMS_LICENSE_KEY=<your Ed25519-signed key>        # unlocks Pro/Enterprise
# LICENSE_PUBLIC_KEY=<PEM>                              # override the embedded verify key (vendor-set; rarely needed)

# ── Prebuilt images (for `docker compose pull`) ─────────────────────────────
# Leave as-is to build from source; set to your registry images for prebuilt.
API_IMAGE=flowcms-api:local
STUDIO_IMAGE=flowcms-studio:local

# ── Optional: Redis  (start with `--profile cache`) ─────────────────────────
# REDIS_URL=redis://redis:6379

# ── Optional: Meilisearch  (start with `--profile search`) ──────────────────
# MEILI_HOST=http://meilisearch:7700
# MEILI_MASTER_KEY=CHANGE_ME_meili_master_key

# ── Asset storage (optional) ────────────────────────────────────────────────
# Default: uploads are stored on local disk (the media_data volume). To store
# them in S3-compatible object storage (Cloudflare R2 / Supabase Storage / AWS S3
# / MinIO) and serve over a CDN, set STORAGE_DRIVER=s3 and fill these in:
# STORAGE_DRIVER=s3
# S3_BUCKET=flowcms-media
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # R2; Supabase: https://<project>.supabase.co/storage/v1/s3
# S3_REGION=auto                                           # R2: auto · Supabase/AWS: the bucket region
# S3_PUBLIC_URL=https://cdn.yoursite.com                   # public base the objects are served from
# S3_FORCE_PATH_STYLE=true                                 # true for Supabase/MinIO; R2 works either way

# ── Optional hardening (sensible defaults already apply) ─────────────────────
# MAX_JSON_BODY=10mb
# MAX_FORM_BODY=1mb
# ALLOW_PRIVATE_FETCH=false   # set true ONLY to reach internal hosts (local Ollama, intranet)

# ── Resource limits (per-container caps; defaults suit a 2–4 GB VPS) ──────────
# The compose file caps each service's memory/CPU so one runaway container can't
# OOM the host. Raise these on larger hosts, or lower on a tiny box. Memory limits
# are hard caps; Node auto-tunes its heap to the api limit. CPU is in cores.
# CADDY_MEM_LIMIT=256M
# STUDIO_MEM_LIMIT=512M
# STUDIO_CPU_LIMIT=1.0
# API_MEM_LIMIT=1G
# API_CPU_LIMIT=2.0
# UPDATER_MEM_LIMIT=256M
# PG_MEM_LIMIT=1G              # raise for large datasets / many connections
# PG_CPU_LIMIT=2.0
# REDIS_MEM_LIMIT=320M
# REDIS_MAXMEMORY=256mb
# MEILI_MEM_LIMIT=512M

# ── Docker access for the updater ────────────────────────────────────────────
# By DEFAULT the updater talks to Docker through a scoped, read-only socket proxy
# (least privilege — it never gets the raw host socket). You don't need to set
# anything for this. To fall back to the direct socket (NOT recommended), set both:
# UPDATER_DOCKER_HOST=
# UPDATER_SOCKET=/var/run/docker.sock
