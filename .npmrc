# Hard-fail `npm install` / `npm ci` when the active Node is outside the engines
# range in package.json (currently Node 22.x). Node 23/24 break this repo's
# toolchain (nest CLI via path-scurry, eslint via ajv, and the NestJS app hangs at
# startup), so failing loudly here is far better than the mysterious hangs those
# versions produce. Use `nvm use` (see .nvmrc) to switch to 22.
engine-strict=true
