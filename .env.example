# ─────────────────────────────────────────────────────────────────────────────
# Flow CMS environment. Copy this file to `.env` and fill in the values:
#     cp .env.example .env
# Generate the two secrets with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (REQUIRED) --------------------------------------------------------
# Point this at any Postgres: the bundled Docker one (below), Neon, Supabase, RDS…
POSTGRES_USER=flowcms
POSTGRES_PASSWORD=flowcms
POSTGRES_DB=flowcms
POSTGRES_PORT=5432
DATABASE_URL=postgresql://flowcms:flowcms@localhost:5432/flowcms?schema=public

# --- Redis (optional — background jobs / webhooks) ------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Security secrets (REQUIRED) ------------------------------------------------
# Encrypts API keys / SMTP creds at rest. CHANGE THESE before any real use.
SECRETS_ENCRYPTION_KEY=replace_me_with_openssl_rand_base64_32
JWT_SECRET=replace_me_with_openssl_rand_base64_32

# --- API + Studio ---------------------------------------------------------------
API_PORT=4000
API_URL=http://localhost:4000
STUDIO_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# --- Frontend (live preview) ----------------------------------------------------
# The public site that renders your content. On first boot it prefills the
# workspace's live-preview URL (Settings → System → Preview URL) so live preview
# works immediately instead of the demo fallback. It never overwrites a URL you've
# already set. Provide one:
#   FRONTEND_URL — the site origin; "/{slug}" is appended automatically.
#   PREVIEW_URL  — a full template if your paths differ (tokens: {slug} {id} {type} {locale}).
# FRONTEND_URL=https://blog.example.com
# PREVIEW_URL=https://blog.example.com/{slug}

# --- Production hardening (optional; sensible defaults in dev) -------------------
# Behind a reverse proxy / CDN (nginx, Cloudflare, a load balancer)? Set the number
# of trusted proxy hops (e.g. 1) so per-IP rate limiting sees the real client IP.
# Leave UNSET on a directly-exposed server so a spoofed X-Forwarded-For header
# can't dodge rate limits.
# TRUST_PROXY=1
# Max request body sizes (large-payload DoS guard). Raise JSON only if you import
# very large payloads; file uploads are capped separately (25 MB).
# MAX_JSON_BODY=10mb
# MAX_FORM_BODY=1mb
# SSRF guard: outbound requests to user-supplied URLs (webhooks, custom AI /
# keyword / AEO endpoints, importers, the SEO crawler) are blocked from reaching
# private/internal/loopback/metadata addresses by default. Set to true ONLY on a
# trusted self-hosted box that must reach internal endpoints (a local Ollama /
# LiteLLM, an intranet WordPress, internal webhooks). Leave off for cloud.
# ALLOW_PRIVATE_FETCH=false

# --- Public self-registration ---------------------------------------------------
# OFF by default: with it off, POST /api/auth/signup is refused and users are added
# by admin invite (the first admin is created via the /welcome first-run wizard).
# Set to true ONLY if you intend an open, public-signup CMS (every signup becomes an
# editor that can upload media + create content). SECURITY_AUDIT_REPORT F-02.
# SIGNUP_ENABLED=false

# --- First-run Super Admin (optional) -------------------------------------------
# Leave these UNSET to boot "unclaimed" and create the admin in the browser /welcome
# wizard. Set BOTH to provision the admin non-interactively (CI / scripted installs)
# and skip the wizard. `npm run db:seed` (local demo) uses these if present.
# SEED_ADMIN_EMAIL=admin@flowcms.local
# SEED_ADMIN_PASSWORD=change-me-to-a-strong-12-char-password
